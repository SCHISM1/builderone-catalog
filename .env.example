# BuilderOne Catalog Pipeline — environment variables
# Copy to .env and fill in real values for the real-adapter swap (Run 4b / post-4a).
# This file contains ONLY placeholders — no real secrets.

# Vendor API keys (real-adapter swap — Run 4b)
BESTBUY_API_KEY=your-bestbuy-api-key-here
TECHPOWERUP_API_KEY=your-techpowerup-api-key-here
KEEPA_API_KEY=your-keepa-api-key-here
WALMART_API_KEY=your-walmart-api-key-here

# LLM (used in motherboard LLM-extraction adapter)
LLM_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# Telegram (human review queue delivery)
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Pipeline config dials
MATCH_THRESHOLD=0.85
FIELD_TRUST_THRESHOLD=0.80

# Batch caps (kill-switches)
MAX_PARTS_PER_RUN=1000
MAX_LLM_CALLS_PER_RUN=200
MAX_BUDGET_PER_RUN=5.00

# Storage
DB_PATH=catalog.db
EXPORT_PATH=catalog_export.json
